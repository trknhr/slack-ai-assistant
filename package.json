{
  "name": "slack-ai-assistant",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "AWS Lambda + Slack Events API + Claude Managed Agents scaffold",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy",
    "sync-agent-tools": "ts-node scripts/sync-agent-tools.ts",
    "import-local-docs": "ts-node scripts/import-local-docs.ts",
    "ingest-markdown": "ts-node scripts/ingest-markdown.ts",
    "extract-pdf-markdown": "ts-node scripts/extract-pdf-markdown.ts",
    "ask-agent": "ts-node scripts/ask-agent.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.88.0",
    "@aws-sdk/client-dynamodb": "3.1029.0",
    "@aws-sdk/client-secrets-manager": "3.1029.0",
    "@aws-sdk/client-s3": "3.1029.0",
    "@aws-sdk/client-sqs": "3.1029.0",
    "@aws-sdk/credential-provider-node": "3.972.31",
    "@aws-sdk/lib-dynamodb": "3.1029.0",
    "@aws-sdk/s3-request-presigner": "3.1029.0",
    "@aws-crypto/sha256-js": "5.2.0",
    "@smithy/protocol-http": "5.3.14",
    "@smithy/signature-v4": "5.3.14",
    "aws-cdk-lib": "2.248.0",
    "constructs": "10.6.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.161",
    "@types/node": "25.6.0",
    "aws-cdk": "2.1118.0",
    "esbuild": "0.28.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.2"
  }
}
